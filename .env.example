# ============================================================
# HomeTown HotSpots — Environment Variables
#
# Copy this file to `.env.local` for local development, and add
# the same three variables in Vercel → Project → Settings →
# Environment Variables for the live site.
# The site runs fine without them — only the forms need them.
# ============================================================

# Your API key from https://resend.com → API Keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where form notifications are delivered (your inbox)
# CONTACT_EMAIL=hello@hometownhotspots.com

# The newsletter list: Resend → Audiences → (your audience) → copy its ID
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ------------------------------------------------------------
# Content management (the /admin studio).
# Create a free project at sanity.io, then copy the project ID
# from its dashboard. Until these are set, the site reads
# content from the files in src/data/ instead.
# ------------------------------------------------------------
# NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxx
# NEXT_PUBLIC_SANITY_DATASET=production
